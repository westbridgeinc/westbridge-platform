// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id               String   @id @default(cuid())
  email            String   @unique
  companyName      String   @map("company_name")
  erpnextCompany   String?  @map("erpnext_company") // ERPNext Company name for row-level scoping
  plan             String   // Starter | Growth | Business
  status           String   @default("pending") // pending | active | past_due | canceled
  twocoOrderId     String?  @map("twoco_order_id")
  twocoCustomerId  String?  @map("twoco_customer_id")
  modulesSelected  String[] @map("modules_selected") // module ids
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  users              User[]
  subscriptions      Subscription[]
  auditLogs          AuditLog[]
  apiKeys            ApiKey[]
  inviteTokens       InviteToken[]
  webhookEndpoints   WebhookEndpoint[]

  @@map("accounts")
}

model User {
  id                   String    @id @default(cuid())
  accountId            String    @map("account_id")
  email                String    /// @pii - Personal Identifiable Information
  name                 String?   /// @pii - Personal Identifiable Information
  role                 String    // "owner" | "admin" | "member"
  passwordHash         String?   @map("password_hash")
  status               String    @default("active") // active | suspended | invited
  failedLoginAttempts  Int       @default(0)
  lockedUntil          DateTime? @map("locked_until")
  lastFailedLogin      DateTime? @map("last_failed_login")
  passwordChangedAt    DateTime? @map("password_changed_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  account             Account              @relation(fields: [accountId], references: [id], onDelete: Cascade)
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]

  @@unique([accountId, email])
  @@index([accountId])
  @@index([email])
  @@map("users")
}

model Session {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  token       String   @unique // SHA-256 hash of the raw token
  erpnextSid  String?  @map("erpnext_sid") // ERPNext session for API proxy
  ipAddress   String?  @map("ip_address") /// @pii - Personal Identifiable Information
  userAgent   String?  @map("user_agent") /// @pii - Personal Identifiable Information
  fingerprint String?  // hash of User-Agent for session binding
  expiresAt   DateTime @map("expires_at")
  lastActiveAt DateTime @default(now()) @map("last_active_at")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([expiresAt])
  @@index([userId])
  @@map("sessions")
}

model Subscription {
  id                    String    @id @default(cuid())
  accountId             String    @map("account_id")
  planId                String    @map("plan_id") // Starter | Growth | Business etc.
  status                String    // active | canceled | past_due | trialing
  currentPeriodStart    DateTime  @map("current_period_start")
  currentPeriodEnd      DateTime  @map("current_period_end")
  twocoSubscriptionId   String?   @map("twoco_subscription_id")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([twocoSubscriptionId])
  @@map("subscriptions")
}

model AuditLog {
  id         String   @id @default(cuid())
  timestamp  DateTime @default(now())
  accountId  String   @map("account_id")
  userId     String?  @map("user_id")
  action     String
  resource   String?
  resourceId String?  @map("resource_id")
  ipAddress  String?  @map("ip_address") /// @pii - Personal Identifiable Information
  userAgent  String?  @map("user_agent") /// @pii - Personal Identifiable Information
  metadata   Json?
  severity   String   @default("info") // info, warn, critical
  outcome    String   @default("success") // success, failure, error

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, timestamp])
  @@index([userId, timestamp])
  @@index([action, timestamp])
  @@index([severity, timestamp])
  @@map("audit_logs")
}

model ApiKey {
  id        String    @id @default(cuid())
  accountId String    @map("account_id")
  keyHash   String    @map("key_hash") // hash of the raw key
  prefix    String    // first few chars for display (e.g. wb_xxxx)
  label     String?
  lastUsedAt DateTime? @map("last_used_at")
  expiresAt  DateTime? @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([keyHash])
  @@index([accountId])
  @@map("api_keys")
}

model InviteToken {
  id        String    @id @default(cuid())
  accountId String    @map("account_id")
  email     String    /// @pii - Personal Identifiable Information
  role      String    @default("member") // owner | admin | member
  tokenHash String    @unique @map("token_hash") // SHA-256 of raw token
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, email])
  @@index([tokenHash])
  @@index([accountId])
  @@map("invite_tokens")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash") // SHA-256 of raw token
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@map("password_reset_tokens")
}

model WebhookEndpoint {
  id                  String    @id @default(cuid())
  accountId           String    @map("account_id")
  url                 String
  events              String[]  // event types this endpoint subscribes to
  secret              String    // HMAC signing secret; stored encrypted at rest (see lib/encryption)
  enabled             Boolean   @default(true)
  consecutiveFailures Int       @default(0) @map("consecutive_failures")
  disabledAt          DateTime? @map("disabled_at") // set when circuit breaker trips; survives restarts
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@map("webhook_endpoints")
}
