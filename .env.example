# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string. Use Docker Compose or a managed database.
DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/westbridge

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── ERPNext ───────────────────────────────────────────────────────────────────
ERPNEXT_URL=http://localhost:8080
# ERPNext API key for server-to-server calls (Admin → API Access in ERPNext)
ERPNEXT_API_KEY=
ERPNEXT_API_SECRET=

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6380

# ── Security ──────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
CSRF_SECRET=

# AES-256 encryption key for PII at rest (ERPNext session IDs etc.)
# Generate: openssl rand -hex 32   (must be exactly 64 hex chars = 32 bytes)
ENCRYPTION_KEY=

# ── 2Checkout (Verifone) payments ─────────────────────────────────────────────
# Get from Merchant Control Panel → Integrations → Webhooks and API
TWOCO_MERCHANT_CODE=
TWOCO_SECRET_WORD=
# Create one product per plan in 2Checkout (Setup → Generate links), paste checkout URLs:
TWOCO_LINK_STARTER=
TWOCO_LINK_BUSINESS=
TWOCO_LINK_ENTERPRISE=

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Sign up at https://resend.com — free tier supports 3,000 emails/month
RESEND_API_KEY=
# Sender address (must be from a verified Resend domain)
EMAIL_FROM=Westbridge <noreply@westbridge.app>

# ── Sentry (optional) ─────────────────────────────────────────────────────────
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ── Docker Compose passwords (required when using docker-compose.yml) ─────────
# Generate: openssl rand -base64 24
POSTGRES_PASSWORD=
MYSQL_ROOT_PASSWORD=
# Generate: openssl rand -base64 24
REDIS_PASSWORD=

# ── Observability ─────────────────────────────────────────────────────────────
# OpenTelemetry OTLP endpoint (e.g. Grafana Cloud, Honeycomb, Jaeger)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=westbridge

# Prometheus metrics scrape token (protects /api/metrics)
# Generate: openssl rand -hex 32
METRICS_TOKEN=

# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ── Deployment ────────────────────────────────────────────────────────────────
# Set by CI pipeline
DEPLOY_STAGE=dev
DEPLOY_REGION=us-east-1
APP_VERSION=
COMMIT_SHA=

# ── Misc ──────────────────────────────────────────────────────────────────────
# Internal account ID for system-level audit log entries
SYSTEM_ACCOUNT_ID=

# ── Analytics ─────────────────────────────────────────────────────────────────
# PostHog project API key (server-side) — get from app.posthog.com
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# PostHog browser key (client-side, safe to expose)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── Claude AI ─────────────────────────────────────────────────────────────────
# Get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
